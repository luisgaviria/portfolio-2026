---
const { projects } = Astro.props;
const getTransitionName = (title: string) => `title-${title.toLowerCase().replace(/\s+/g, '-')}`;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-12 border-t border-slate-100 dark:border-slate-900 pt-20">
  {projects.map((project) => (
    <div class="group relative flex flex-col h-full">

      {/* 1. THE MAIN CARD LINK
          This is a clean, single <a> wrapping the content.
          No nested links = no browser repair = smooth transition.
      */}
      <a
        href="/projects"
        class="flex flex-col h-full bg-white/70 dark:bg-slate-900/50 backdrop-blur-md border border-slate-200 dark:border-slate-800 rounded-2xl p-6 md:p-10 transition-all hover:shadow-2xl hover:border-slate-300 dark:hover:border-slate-700"
      >
        <div class="flex items-start mb-6 md:mb-8 justify-between">
          <div class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800/80 text-slate-600 dark:text-slate-300 rounded-md text-[10px] font-black uppercase tracking-widest">
            {project.role}
          </div>
          
          {/* Visual Icon (Not a link itself, just a visual cue since the whole card is the link) */}
          <div class="text-slate-400 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>
        </div>

        <div
          style={`view-transition-name: ${getTransitionName(project.title)}`}
          class="text-2xl md:text-3xl font-extrabold text-slate-900 dark:text-white mb-3 tracking-tight"
        >
          {project.title}
        </div>

        <p class="text-sm md:text-base text-slate-600 dark:text-slate-400 leading-relaxed mb-6 flex-grow">
          {project.desc}
        </p>

        <div class="flex flex-wrap gap-2 mt-auto">
          {project.tech.map((t) => (
            <span class="text-[10px] md:text-[11px] font-bold text-slate-700 dark:text-slate-200 bg-slate-100 dark:bg-slate-800/40 px-2.5 py-1 rounded-md border border-slate-200/50 dark:border-slate-700/50">
              {t}
            </span>
          ))}
        </div>
      </a>
    </div>
  ))}
</div>