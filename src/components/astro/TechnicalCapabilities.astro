---
import { getEntry } from 'astro:content';

const capabilitiesData = await getEntry('capabilities', 'home');
const { capabilities } = capabilitiesData.data;
---

<section class="py-20 border-t border-slate-100 dark:border-slate-900">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
    {capabilities.map((cap) => (
      <div class="group">
        <h3 class="text-[10px] uppercase tracking-[0.3em] font-black text-slate-400 mb-6 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">
          {cap.category}
        </h3>
        <ul class="space-y-4">
          {cap.items.map((item) => (
            <li class="text-lg md:text-xl font-bold text-slate-900 dark:text-white tracking-tight">
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>